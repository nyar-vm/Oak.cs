<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net11.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>preview</LangVersion>
    <RootNamespace>Oak.Vue</RootNamespace>
    <AssemblyName>Oak.Vue</AssemblyName>
    <PackageId>Oak.Vue</PackageId>
    <Version>0.0.0</Version>
    <Authors>Nyar Team - Oak Group</Authors>
    <Description>Oak Vue 单文件组件解析器，支持 .vue 文件的 template + script + style 解析</Description>
    <PackageProjectUrl>https://github.com/nyar-vm/Oak.cs</PackageProjectUrl>
    <RepositoryUrl>https://github.com/nyar-vm/Oak.cs</RepositoryUrl>
    <PackageLicenseExpression>MPL-2.0</PackageLicenseExpression>
    <PackageTags>parser;vue;sfc;template;script;style;oak</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Oak\Oak.csproj" />
  </ItemGroup>

</Project>
