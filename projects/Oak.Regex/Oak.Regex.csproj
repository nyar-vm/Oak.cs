<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net11.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <LangVersion>preview</LangVersion>
        <RootNamespace>Oak.Regex</RootNamespace>
        <AssemblyName>Oak.Regex</AssemblyName>
        <PackageId>Oak.Regex</PackageId>
        <Version>0.0.0</Version>
        <Authors>Nyar Team - Oak Group</Authors>
        <Description>Oak 正Reg表达式文本解析器</Description>
        <PackageProjectUrl>https://github.com/nyar-vm/Oak.cs</PackageProjectUrl>
        <RepositoryUrl>https://github.com/nyar-vm/Oak.cs</RepositoryUrl>
        <PackageLicenseExpression>MPL-2.0</PackageLicenseExpression>
        <PackageTags>parser;regex;oak</PackageTags>
    </PropertyGroup>

    <ItemGroup>
        <Compile Remove="Oak.Regex.Tests\**" />
        <None Remove="Oak.Regex.Tests\**" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\Oak\Oak.csproj" />
    </ItemGroup>

</Project>
